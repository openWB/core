    "@inkline/inkline": "^3.2.2",
    "buffer": "^6.0.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-luxon": "^1.3.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "events": "^3.3.0",
    "luxon": "^3.7.2",
    "mqtt": "^5.15.1",
    "node-stdlib-browser": "^1.3.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
